# =============================================================================
# vie-backend — Python / FastAPI .gitignore
# =============================================================================

# ---------------- Environment variables ----------------
.env
.env.*
!.env.example

# ---------------- Python runtime -----------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ---------------- Virtual environments -----------------
.venv/
venv/
env/
ENV/
.python-version

# ---------------- Package / build ----------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST
site/
wheels/
pip-wheel-metadata/
share/python-wheels/

# ---------------- Testing / coverage -------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
test-results/

# ---------------- Type checking ------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ---------------- Linters / formatters -----------------
.ruff_cache/

# ---------------- Databases ----------------------------
*.db
*.sqlite
*.sqlite3
*.sql.bak
*.dump
db_data/
postgres_data/
redis_data/

# ---------------- Media / audio uploads ----------------
*.wav
*.mp3
*.m4a
*.ogg
*.flac
*.aac
uploads/
media/

# ---------------- Misc ---------------------------------
tmp/
temp/
/tmp/
*.log
*.pid
instance/
.webassets-cache

# ---------------- Operating Systems --------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.nfs*

# ---------------- Editors / IDEs -----------------------
.vscode/
!.vscode/extensions.json
.idea/
*.iml
[._]*.sw[a-p]
